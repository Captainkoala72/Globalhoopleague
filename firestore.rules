rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // CORE PRIMITIVES & VALIDATION
    // -------------------------------------------------------------------------
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return request.auth.uid == userId; }
    function isAdmin() { return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // -------------------------------------------------------------------------
    // SCHEMA BLUEPRINTS
    // -------------------------------------------------------------------------

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role', 'balance']) &&
             data.email is string && data.email.size() <= 200 &&
             data.role in ['bettor', 'admin'] &&
             data.balance is number &&
             (!data.keys().hasAny(['lastAdWatchedAt']) || data.lastAdWatchedAt is number);
    }

    function isValidTeam(data) {
      return data.keys().hasAll(['name', 'conference', 'stats']) &&
             data.name is string && data.name.size() <= 100 &&
             data.conference in ['USA', 'World'] &&
             data.stats is map &&
             data.stats.keys().hasAll(['offense', 'defense', 'overall', 'ppg', 'oppg', 'fgPct', 'threePtPct', 'topg', 'wins', 'losses']) &&
             data.stats.offense is number && data.stats.defense is number && data.stats.overall is number &&
             data.stats.ppg is number && data.stats.oppg is number && data.stats.fgPct is number && data.stats.threePtPct is number &&
             data.stats.topg is number && data.stats.wins is number && data.stats.losses is number;
    }

    function isValidGlobalSettings(data) {
      return data.keys().hasAll(['formulaWeights']) &&
             data.formulaWeights is map &&
             data.formulaWeights.keys().hasAll(['starRatings', 'seasonAverages', 'record', 'homeCourt']) &&
             data.formulaWeights.starRatings is number && data.formulaWeights.seasonAverages is number && 
             data.formulaWeights.record is number && data.formulaWeights.homeCourt is number;
    }

    function isValidMatch(data) {
      return data.keys().hasAll(['awayTeamId', 'homeTeamId', 'status']) &&
             data.awayTeamId is string && data.homeTeamId is string &&
             data.status in ['scheduled', 'active', 'settled', 'cancelled'] &&
             (!data.keys().hasAny(['date']) || data.date is string);
    }

    function isValidBet(data) {
      return data.keys().hasAll(['userId', 'matchupId', 'selection', 'stake', 'status', 'timestamp']) &&
             data.userId is string && data.matchupId is string &&
             data.selection is map && data.stake is number &&
             data.status in ['open', 'won', 'lost', 'push', 'refunded'] && data.timestamp is number;
    }

    // -------------------------------------------------------------------------
    // FORBIDDEN CATCH-ALL
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // 1. USERS COLLECTION
    // -------------------------------------------------------------------------
    match /users/{userId} {
      allow read: true;
      allow create: if isSignedIn() && isValidId(userId) && isOwner(userId) &&
                       isValidUser(incoming()) && incoming().role == 'bettor' && incoming().balance == 1000;
      allow update: if isSignedIn() && (isAdmin() || (isOwner(userId)));
      allow delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // 2. TEAMS COLLECTION
    // -------------------------------------------------------------------------
    match /teams/{teamId} {
      allow read: true;
      allow create: if isAdmin() && isValidId(teamId) && isValidTeam(incoming());
      allow update: if isAdmin() && isValidTeam(incoming());
      allow delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // 3. GLOBAL SETTINGS COLLECTION
    // -------------------------------------------------------------------------
    match /global/{settingId} {
      allow read: true;
      allow create: if isAdmin() && isValidId(settingId) && settingId == 'settings' && isValidGlobalSettings(incoming());
      allow update: if isAdmin() && isValidGlobalSettings(incoming());
      allow delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // 4. MATCHES COLLECTION
    // -------------------------------------------------------------------------
    match /matches/{matchId} {
      allow read: true;
      allow create: if isAdmin() && isValidId(matchId) && isValidMatch(incoming());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    // -------------------------------------------------------------------------
    // 5. BETS COLLECTION
    // -------------------------------------------------------------------------
    match /bets/{betId} {
      allow read: if isSignedIn() && isOwner(resource.data.userId);
      allow read: if isAdmin();
      allow create: if isSignedIn() && isValidId(betId) && isOwner(incoming().userId) && isValidBet(incoming());
      allow update: if isSignedIn() && (isAdmin() || (isValidBet(incoming()) && 
        (isOwner(existing().userId) && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'actualPayout', 'homeScore', 'awayScore']))
      ));
      allow delete: if isAdmin();
    }
    // -------------------------------------------------------------------------
    // 6. CHAT MESSAGES COLLECTION
    // -------------------------------------------------------------------------
    match /chat_messages/{messageId} {
      allow read: true;
      allow create: if isSignedIn() && isOwner(incoming().userId);
      allow update: if false;
      allow delete: if isAdmin();
    }
  }
}
